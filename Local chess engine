local PST={p={{0,0,0,0,0,0,0,0},{50,50,50,50,50,50,50,50},{10,10,20,30,30,20,10,10},{5,5,10,25,25,10,5,5},{0,0,0,20,20,0,0,0},{5,-5,-10,0,0,-10,-5,5},{5,10,10,-20,-20,10,10,5},{0,0,0,0,0,0,0,0}},n={{-50,-40,-30,-30,-30,-30,-40,-50},{-40,-20,0,0,0,0,-20,-40},{-30,0,10,15,15,10,0,-30},{-30,5,15,20,20,15,5,-30},{-30,0,15,20,20,15,0,-30},{-30,5,10,15,15,10,5,-30},{-40,-20,0,5,5,0,-20,-40},{-50,-40,-30,-30,-30,-30,-40,-50}},b={{-20,-10,-10,-10,-10,-10,-10,-20},{-10,0,0,0,0,0,0,-10},{-10,0,5,10,10,5,0,-10},{-10,5,5,10,10,5,5,-10},{-10,0,10,10,10,10,0,-10},{-10,10,10,10,10,10,10,-10},{-10,5,0,0,0,0,5,-10},{-20,-10,-10,-10,-10,-10,-10,-20}},r={{0,0,0,0,0,0,0,0},{5,10,10,10,10,10,10,5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{-5,0,0,0,0,0,0,-5},{0,0,0,5,5,0,0,0}},q={{-20,-10,-10,-5,-5,-10,-10,-20},{-10,0,0,0,0,0,0,-10},{-10,0,5,5,5,5,0,-10},{-5,0,5,5,5,5,0,-5},{0,0,5,5,5,5,0,-5},{-10,5,5,5,5,5,0,-10},{-10,0,5,0,0,0,0,-10},{-20,-10,-10,-5,-5,-10,-10,-20}},k={{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-30,-40,-40,-50,-50,-40,-40,-30},{-20,-30,-30,-40,-40,-30,-30,-20},{-10,-20,-20,-20,-20,-20,-20,-10},{20,20,0,0,0,0,20,20},{20,30,10,0,0,10,30,20}}}
local function evaluateBoard(b) local s=0; for r=1,8 do for c=1,8 do local p=b[r][c]; if p~="" then local ms=PV[p] or 0; local pt,pc=p:lower(),getPieceColor(p); local ps=0; if PST[pt] then ps=(pc=="White") and PST[pt][r][c] or PST[pt][9-r][c] end; s+=(pc=="Black") and (ms-ps) or (ms+ps) end end end; return s end
local MAX_DEPTH_LOCAL,minimax_=2,nil; minimax_=function(b,d,a,be,isM) checkYield(); if d==0 then return evaluateBoard(b) end; local m=generateLegalMoves(b,isM and "Black" or "White"); if isM then local me=-math.huge; for _,mo in ipairs(m) do local nb=cloneBoard(b) nb[mo.toR][mo.toC]=mo.piece nb[mo.fromR][mo.fromC]="" local e=minimax_(nb,d-1,a,be,false) me=math.max(me,e) a=math.max(a,e) if be<=a then break end end return me else local me=math.huge; for _,mo in ipairs(m) do local nb=cloneBoard(b) nb[mo.toR][mo.toC]=mo.piece nb[mo.fromR][mo.fromC]="" local e=minimax_(nb,d-1,a,be,true) me=math.min(me,e) be=math.min(be,e) if be<=a then break end end return me end end

local function findBestMoveFor(color) 
    local board = copyBoard(squares)
    local legalMoves = generateLegalMoves(board, color)
    if #legalMoves == 0 then return end
    local bestMoves, bestEval = {}, (color == "Black" and math.huge or -math.huge)
    for _, move in ipairs(legalMoves) do 
        local nb = cloneBoard(board) nb[move.toR][move.toC]=move.piece nb[move.fromR][move.fromC]=""
        local eval = minimax_(nb, MAX_DEPTH_LOCAL - 1, -math.huge, math.huge, color == "White")
        if (color == "Black" and eval < bestEval) or (color == "White" and eval > bestEval) then bestEval, bestMoves = eval, {move}
        elseif eval == bestEval then table.insert(bestMoves, move) end
    end
    return bestMoves[math.random(1, #bestMoves)]
end

-- --- UI Controls ---
local function clearHighlights() 
    for r=1,8 do for c=1,8 do if originalColors[r] and squares[r][c] then squares[r][c].BackgroundColor3 = originalColors[r][c] end end end 
end

local function highlightValidMoves(sr,sc, pieceColor) 
    local lm=generateLegalMoves(copyBoard(squares),pieceColor)
    for _,m in ipairs(lm) do if m.fromR==sr and m.fromC==sc then squares[m.toR][m.toC].BackgroundColor3=(m.captured~="") and Color3.fromRGB(200,50,50) or Color3.fromRGB(50,200,50) end end 
end

local function clearSuggestionHighlight()
    if currentSuggestion then
        local fr, tr = currentSuggestion.fromR, currentSuggestion.toR
        local fc, tc = currentSuggestion.fromC, currentSuggestion.toC
        squares[fr][fc].BackgroundColor3 = originalColors[fr][fc]
        squares[tr][tc].BackgroundColor3 = originalColors[tr][tc]
        currentSuggestion = nil
    end
end

local function showSuggestion(suggestion)
    if not suggestion then return end
    clearSuggestionHighlight()
    currentSuggestion = suggestion
    squares[suggestion.fromR][suggestion.fromC].BackgroundColor3 = Color3.fromRGB(0, 200, 200)
    squares[suggestion.toR][suggestion.toC].BackgroundColor3 = Color3.fromRGB(0, 200, 200)
end

local function applyMoveToBoard(board, move)
    local nb = cloneBoard(board)
    nb[move.toR][move.toC] = move.piece
    nb[move.fromR][move.fromC] = ""
    return nb
end

local function executeMove(move, color, promo)
    local fr,fc,tr,tc,mp = move.fromR,move.fromC,move.toR,move.toC,move.piece
    clearHighlights()
    table.insert(moveHistory,{fromR=fr,fromC=fc,toR=tr,toC=tc,movedPiece=mp,capturedPiece=squares[tr][tc].Text,previousHasMoved=copyHasMoved(hasMoved)})
    squares[tr][tc].Text, squares[tr][tc].TextColor3, squares[fr][fc].Text = mp, getPieceTextColor(color), ""
    if mp:lower()=='k' and math.abs(tc-fc)==2 then
        local rc, nrc = (tc>fc) and 8 or 1, (tc>fc) and 6 or 4
        squares[fr][nrc].Text, squares[fr][rc].Text = squares[fr][rc].Text, ""
        squares[fr][nrc].TextColor3 = getPieceTextColor(color)
    end
    if mp:lower() == 'p' and (tr == 1 or tr == 8) then squares[tr][tc].Text = (color == "White" and (promo or "q"):lower() or (promo or "Q"):upper()) end
    hasMoved[mp]=true
    squares[fr][fc].BackgroundColor3, squares[tr][tc].BackgroundColor3 = Color3.fromRGB(255,255,0), Color3.fromRGB(0,150,255)
    currentTurn = (color=="White") and "Black" or "White"
    stateVersion = stateVersion + 1
    statusLabel.Text = "Status: ("..currentTurn.."'s Turn)"
end

local function executeAIMove(color)
    if currentTurn ~= color or gamePaused or isThinking then return end
    isThinking = true
    
    local apiToUse = currentApi
    if isTraining then
        apiToUse = (color == "White") and whiteApi or blackApi
    end
    
    statusLabel.Text = "Thinking... (" .. apiToUse .. ")"
    task.wait(0.1)

    local uci = getBestMoveFromAPI(getFEN(), apiToUse)
    if uci then
        local fr,fc,tr,tc,promo = uciToMove(uci)
        executeMove({fromR=fr,fromC=fc,toR=tr,toC=tc,piece=squares[fr][fc].Text}, color, promo)
    else
        local move = findBestMoveFor(color)
        if move then executeMove(move, color) end
    end
    isThinking = false
end

local function trainingLoop()
    while isTraining and not gamePaused do
        if not isThinking then executeAIMove(currentTurn) end
        task.wait(0.5)
    end
end

trainButton.MouseButton1Click:Connect(function()
