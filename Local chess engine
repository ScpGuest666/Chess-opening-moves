    if not hasMoved["k"] then
        if not hasMoved["r8"] then castling = castling .. "K" end
        if not hasMoved["r1"] then castling = castling .. "Q" end
    end
    if not hasMoved["K"] then
        if not hasMoved["R8"] then castling = castling .. "k" end
        if not hasMoved["R1"] then castling = castling .. "q" end
    end
    return fen .. " " .. activeColor .. " " .. (castling == "" and "-" or castling) .. " - 0 1"
end

local function uciToMove(uci)
    if not uci or #uci < 4 then return nil end
    return 9 - tonumber(uci:sub(2,2)), uci:sub(1,1):byte() - 96, 9 - tonumber(uci:sub(4,4)), uci:sub(3,3):byte() - 96, uci:sub(5,5)
end

local function getBestMoveFromAPI(fen, apiOverride)
    local apiUsed = apiOverride or currentApi
    if stockfishDepth <= 0 or apiUsed == "Local API" then return nil end
    local bestMoveStr = nil
    local function fetch(url, method, body)
        if req then return req({Url = url, Method = method or "GET", Body = body, Headers = {["Content-Type"] = "application/json"}}).Body
        elseif type(game.HttpGet) == "function" and method ~= "POST" then return game:HttpGet(url) end
    end
    
    if apiUsed == "ShashChess (Poco)" then
        local url = POCO_URL .. "/getmove?fen=" .. HttpService:UrlEncode(fen) .. "&depth=" .. stockfishDepth
        local success, res = pcall(function() return fetch(url, "GET") end)
        if success and res and res ~= "" then
            bestMoveStr = res
        else
            statusLabel.Text = "Error: Cannot connect to Poco!"
            task.wait(2)
        end
    elseif apiUsed == "Stockfish" then
        local res = fetch("https://stockfish.online/api/s/v2.php?fen=" .. HttpService:UrlEncode(fen) .. "&depth=" .. stockfishDepth)
        if res then local data = HttpService:JSONDecode(res) if data.success then bestMoveStr = data.bestmove:match("bestmove%s+(%S+)") end end
    elseif apiUsed == "ChessAPI" or apiUsed == "Saychess" then
        local res = fetch("https://chess-api.com/v1", "POST", HttpService:JSONEncode({fen = fen, depth = stockfishDepth}))
        if res then local data = HttpService:JSONDecode(res) bestMoveStr = data.move end
    end
    return bestMoveStr
end

